# CertDeck — Plantilla de variables de entorno (SÍ versionar)
# Copia este archivo a `app/.env` y rellena los valores reales.
# `app/.env` está excluido por .gitignore y nunca debe commitearse.

# --- Variante Vite (compatibilidad / apps compartidas) ---
# URL del proyecto Supabase
VITE_SUPABASE_URL=
# Clave pública (publishable / anon) de Supabase para el cliente
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- Variante Next.js (la que lee el frontend del proyecto) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
